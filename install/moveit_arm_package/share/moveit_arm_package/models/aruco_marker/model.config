<?xml version="1.0"?>
<model>
  <name>aruco_marker</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>
  <description>
    ArUco marker (DICT_4X4_50, id 0) as a thin textured plate. The material
    script ArucoMarker/Marker0 is referenced via model://aruco_marker by other
    SDF visuals (e.g. the green_block in blocks.world), so this model mainly
    exists to make the material/texture resolvable on GAZEBO_MODEL_PATH.
  </description>
</model>
