// OGRE material for the ArUco marker texture used in Gazebo Classic.
// lighting off keeps the black/white pattern crisp regardless of scene lighting;
// filtering none avoids blurring the marker edges (important for detection).
material ArucoMarker/Marker0
{
  technique
  {
    pass
    {
      lighting off

      texture_unit
      {
        texture aruco_0.png
        filtering none
      }
    }
  }
}
