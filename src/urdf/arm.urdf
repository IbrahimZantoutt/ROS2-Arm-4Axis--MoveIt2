<?xml version="1.0"?>
<robot name="arm_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Fixed anchor so Gazebo doesn't drop the robot under gravity -->
    <link name="world"/>
    <joint name="world_joint" type="fixed">
        <parent link="world"/>
        <child link="robot_base"/>
        <!-- z=0.05 places the bottom face of the 0.1-tall base exactly on the ground -->
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
    </joint>

    <link name="robot_base">
        <visual>
            <geometry>
                <box size="0.3 0.15 0.1"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <box size="0.3 0.15 0.1"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.001354" ixy="0" ixz="0"
                                    iyy="0.004167" iyz="0"
                                                   izz="0.004688"/>
        </inertial>
    </link>

    <link name="spin_link">
        <visual>
            <geometry>
                <sphere radius="0.035"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.0000245" ixy="0" ixz="0"
                                     iyy="0.0000245" iyz="0"
                                                     izz="0.0000245"/>
        </inertial>
    </link>

    <joint name="spin_main_joint" type="revolute">
        <parent link="robot_base"/>
        <child link="spin_link"/>
        <origin xyz="0 0 0.06" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14159" upper="3.14159" effort="10" velocity="1"/>
        <dynamics damping="0.5" friction="0.1"/>
    </joint>

    <link name="spin_arm">
        <visual>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.03" length="0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.03" length="0.1"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.05"/>
            <mass value="0.05"/>
            <inertia ixx="0.0000529" ixy="0" ixz="0"
                                     iyy="0.0000529" iyz="0"
                                                     izz="0.0000225"/>
        </inertial>
    </link>

    <!-- passive structural joint — always at 0, fixed for simulation -->
    <joint name="spin_arm_joint" type="fixed">
        <parent link="spin_link"/>
        <child link="spin_arm"/>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </joint>

    <link name="shoulder_link">
        <visual>
            <geometry>
                <sphere radius="0.035"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.0000245" ixy="0" ixz="0"
                                     iyy="0.0000245" iyz="0"
                                                     izz="0.0000245"/>
        </inertial>
    </link>

    <joint name="shoulder_main_joint" type="revolute">
        <parent link="spin_arm"/>
        <child link="shoulder_link"/>
        <origin xyz="0 0 0.1" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
        <dynamics damping="0.5" friction="0.1"/>
    </joint>

    <link name="shoulder_arm">
        <visual>
            <origin xyz="0 0 0.15" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.03" length="0.4"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.15" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.03" length="0.4"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.15"/>
            <mass value="0.15"/>
            <inertia ixx="0.002034" ixy="0" ixz="0"
                                    iyy="0.002034" iyz="0"
                                                   izz="0.0000675"/>
        </inertial>
    </link>

    <!-- passive structural joint — always at 0, fixed for simulation -->
    <joint name="shoulder_arm_joint" type="fixed">
        <parent link="shoulder_link"/>
        <child link="shoulder_arm"/>
        <origin xyz="0 0 0.04" rpy="0 0 0"/>
    </joint>

    <link name="elbow_link">
        <visual>
            <geometry>
                <sphere radius="0.035"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.0000245" ixy="0" ixz="0"
                                     iyy="0.0000245" iyz="0"
                                                     izz="0.0000245"/>
        </inertial>
    </link>

    <joint name="elbow_main_joint" type="revolute">
        <parent link="shoulder_arm"/>
        <child link="elbow_link"/>
        <origin xyz="0 0 0.35" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-2.356" upper="2.356" effort="10" velocity="1"/>
        <dynamics damping="0.5" friction="0.1"/>
    </joint>

    <link name="elbow_arm">
        <visual>
            <origin xyz="0 0 0.15" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.03" length="0.35"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.15" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.03" length="0.35"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.15"/>
            <mass value="0.12"/>
            <inertia ixx="0.001252" ixy="0" ixz="0"
                                    iyy="0.001252" iyz="0"
                                                   izz="0.000054"/>
        </inertial>
    </link>

    <!-- passive structural joint — always at 0, fixed for simulation -->
    <joint name="elbow_arm_joint" type="fixed">
        <parent link="elbow_link"/>
        <child link="elbow_arm"/>
        <origin xyz="0 0 0.035" rpy="0 0 0"/>
    </joint>

    <link name="wrist_link">
        <visual>
            <geometry>
                <sphere radius="0.035"/>
            </geometry>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.03"/>
            <inertia ixx="0.0000147" ixy="0" ixz="0"
                                     iyy="0.0000147" iyz="0"
                                                     izz="0.0000147"/>
        </inertial>
    </link>

    <joint name="wrist_main_joint" type="revolute">
        <parent link="elbow_arm"/>
        <child link="wrist_link"/>
        <origin xyz="0 0 0.32" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-2.094" upper="2.094" effort="10" velocity="1"/>
        <dynamics damping="0.5" friction="0.1"/>
    </joint>

    <link name="wrist_arm">
        <visual>
            <origin xyz="0 0 0.025" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.012" length="0.05"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.025" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.012" length="0.05"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.025"/>
            <mass value="0.02"/>
            <inertia ixx="0.000004887" ixy="0" ixz="0"
                                       iyy="0.000004887" iyz="0"
                                                         izz="0.00000144"/>
        </inertial>
    </link>

    <!-- passive structural joint — always at 0, fixed for simulation -->
    <joint name="wrist_arm_joint" type="fixed">
        <parent link="wrist_link"/>
        <child link="wrist_arm"/>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </joint>

    <link name="gripper_base">
        <visual>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <box size="0.02 0.08 0.02"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry>
                <box size="0.02 0.02 0.02"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.05"/>
            <mass value="0.03"/>
            <inertia ixx="0.000017" ixy="0" ixz="0"
                                    iyy="0.000002" iyz="0"
                                                   izz="0.000017"/>
        </inertial>
    </link>

    <joint name="gripper_base_joint" type="fixed">
        <parent link="wrist_arm"/>
        <child link="gripper_base"/>
        <origin xyz="0 0 0.01" rpy="0 0 0"/>
    </joint>

    <link name="gripper_left_finger">
        <visual>
            <origin xyz="0 0.025 0.035" rpy="0 0 0"/>
            <geometry>
                <box size="0.015 0.015 0.045"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0.025 0.02" rpy="0 0 0"/>
            <geometry>
                <box size="0.015 0.015 0.045"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0.025 0.035"/>
            <mass value="0.01"/>
            <inertia ixx="0.000001875" ixy="0" ixz="0"
                                       iyy="0.000001875" iyz="0"
                                                         izz="0.000000375"/>
        </inertial>
    </link>

    <joint name="gripper_left_finger_joint" type="prismatic">
        <parent link="gripper_base"/>
        <child link="gripper_left_finger"/>
        <origin xyz="0 0 0.045" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-0.04" upper="0.04" effort="5" velocity="0.1"/>
        <dynamics damping="0.1" friction="0.05"/>
    </joint>

    <link name="gripper_right_finger">
        <visual>
            <origin xyz="0 -0.025 0.035" rpy="0 0 0"/>
            <geometry>
                <box size="0.015 0.015 0.045"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 -0.025 0.035" rpy="0 0 0"/>
            <geometry>
                <box size="0.015 0.015 0.045"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 -0.025 0.035"/>
            <mass value="0.01"/>
            <inertia ixx="0.000001875" ixy="0" ixz="0"
                                       iyy="0.000001875" iyz="0"
                                                         izz="0.000000375"/>
        </inertial>
    </link>

    <joint name="gripper_right_finger_joint" type="prismatic">
        <parent link="gripper_base"/>
        <child link="gripper_right_finger"/>
        <origin xyz="0 0 0.045" rpy="0 0 0"/>
        <axis xyz="0 -1 0"/>
        <limit lower="-0.04" upper="0.04" effort="5" velocity="0.1"/>
        <dynamics damping="0.1" friction="0.05"/>
    </joint>

    <!-- ============================================================ -->
    <!-- ros2_control hardware interface (used by Gazebo simulation)  -->
    <!-- ============================================================ -->
    <ros2_control name="GazeboSystem" type="system">
        <hardware>
            <plugin>gazebo_ros2_control/GazeboSystem</plugin>
        </hardware>
        <joint name="shoulder_main_joint">
            <command_interface name="position">
                <param name="min">-1.57</param>
                <param name="max">1.57</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="elbow_main_joint">
            <command_interface name="position">
                <param name="min">-2.356</param>
                <param name="max">2.356</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="wrist_main_joint">
            <command_interface name="position">
                <param name="min">-2.094</param>
                <param name="max">2.094</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="spin_main_joint">
            <command_interface name="position">
                <param name="min">-3.14159</param>
                <param name="max">3.14159</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="gripper_left_finger_joint">
            <command_interface name="position">
                <param name="min">-0.04</param>
                <param name="max">0.04</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="gripper_right_finger_joint">
            <command_interface name="position">
                <param name="min">-0.04</param>
                <param name="max">0.04</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>

    <!-- Gazebo plugin — loads controllers from controllers.yaml -->
    <gazebo>
        <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
            <parameters>$(find main_arm_package)/config/controllers.yaml</parameters>
        </plugin>
    </gazebo>

    <gazebo reference="gripper_left_finger">
        <mu1>10.0</mu1>
        <mu2>10.0</mu2>
        <kp>1e6</kp>
        <kd>100.0</kd>
        <sensor name="left_finger_contact" type="contact">
            <always_on>true</always_on>
            <update_rate>100</update_rate>
            <contact>
                <collision>gripper_left_finger_collision</collision>
            </contact>
            <plugin name="left_finger_bumper" filename="libgazebo_ros_bumper.so">
                <ros>
                    <remapping>bumper_states:=gripper_left_contact</remapping>
                </ros>
                <frame_name>world</frame_name>
            </plugin>
        </sensor>
    </gazebo>

    <gazebo reference="gripper_right_finger">
        <mu1>1.5</mu1>
        <mu2>1.5</mu2>
        <kp>1e4</kp>
        <kd>10.0</kd>
        <sensor name="right_finger_contact" type="contact">
            <always_on>true</always_on>
            <update_rate>100</update_rate>
            <contact>
                <collision>gripper_right_finger_collision</collision>
            </contact>
            <plugin name="right_finger_bumper" filename="libgazebo_ros_bumper.so">
                <ros>
                    <remapping>bumper_states:=gripper_right_contact</remapping>
                </ros>
                <frame_name>world</frame_name>
            </plugin>
        </sensor>
    </gazebo>

</robot>
